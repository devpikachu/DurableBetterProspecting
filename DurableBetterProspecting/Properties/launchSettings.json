{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "Client": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "\"$(SolutionDir)vendor/vs/Vintagestory.dll\" --tracelog --dataPath \"$(ProjectDir)run\" --addModPath \"$(ProjectDir)bin/$(Configuration)\" --addOrigin \"$(ProjectDir)assets\"",
      "workingDirectory": "$(SolutionDir)vendor/vs"
    },
    "Server": {
      "commandName": "Executable",
      "executablePath": "dotnet",
      "commandLineArgs": "\"$(SolutionDir)vendor/vs/VintagestoryServer.dll\" --tracelog --dataPath \"$(ProjectDir)run\" --addModPath \"$(ProjectDir)bin/$(Configuration)\" --addOrigin \"$(ProjectDir)assets\"",
      "workingDirectory": "$(SolutionDir)vendor/vs"
    }
  }
}
